{
  "errands": {
    "command": "npx",
    "args": [
      "-y",
      "mcp-remote",
      "https://errands.instawork.ai/mcp",
      "--transport",
      "http-only",
      "--header",
      "Authorization:${ERRANDS_AUTH_HEADER}"
    ],
    "env": {
      "ERRANDS_AUTH_HEADER": "Bearer YOUR_TOKEN_HERE"
    }
  }
}
